--LEFT JOIN: List all VIPs and list whether they have RSVP'd for the welcome event, include VIPs who may not have made a reservation.
SELECT v.member_id
, v.first_name
, v.last_name
, r.welcome_rsvp 
FROM vips v
LEFT JOIN reservations r 
ON v.member_id = r.member_id
;

--INNER JOIN: Find the member id's of VIP's who are staying at the Marriott hotel. 
SELECT r.member_id
FROM reservations r
INNER JOIN hotels h 
ON r.hotel = h.hotel_id
WHERE hotel_name = 'Marriott'
;

--Multiple JOINs: Retrieve the first & last names of welcome party attendees & the event type they are attending.
SELECT r.welcome_rsvp
, v.first_name
, v.last_name
, e.event_type
FROM reservations r
INNER JOIN vips v
ON r.member_id = v.member_id
INNER JOIN events e 
ON e.event_id = v.event
WHERE welcome_rsvp = 1
; 


