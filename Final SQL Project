#1.
Show the Top 5 Countries with the highest sales starting from highest to lowest. 

SELECT BillingCountry
, SUM(Total) AS County_Total_Spend
FROM chinook.invoices
GROUP BY BillingCountry
ORDER BY SUM(Total) desc
LIMIT 5
; 

#2.
Show the Top 3 Genres with the highest sales.

SELECT g.Name
, SUM(ii.UnitPrice*Quantity) AS Genre_Total
FROM invoice_items ii
INNER JOIN tracks t
ON ii.TrackId=t.TrackId
INNER JOIN genres g
ON g.GenreId=t.GenreId
GROUP BY g.Name
ORDER BY SUM(ii.UnitPrice*Quantity) desc
LIMIT 3

#3.
Show the Total Sales volume for each Sales Agent from highest to lowest.

SELECT e.FirstName
, e.LastName
, SUM(i.Total) Total_Sales
FROM invoices i
INNER JOIN customers c
ON i.CustomerId=c.CustomerId
INNER JOIN employees e
ON c.SupportRepId=e.EmployeeId
GROUP BY e.FirstName
ORDER BY SUM(i.Total) desc

#4. 
Calculate the AVG Sales for the month of January 2010 (Round your answer to the nearest hundreths place)

SELECT ROUND(AVG(Total),2)
FROM Invoices
WHERE InvoiceDate LIKE '2010-01%'

#5.
Show the Artist Name & the Total Sales associated to each one.

SELECT ar.Name
, SUM(ii.UnitPrice*Quantity) AS Artist_Total
FROM artists ar
INNER JOIN albums al
ON ar.ArtistId=al.ArtistId
INNER JOIN tracks t
ON t.AlbumId=al.AlbumId
INNER JOIN invoice_items ii
ON ii.TrackId=t.TrackId
GROUP BY ar.Name



